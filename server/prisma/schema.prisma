generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ============================================================
// 用户与角色
// ============================================================
model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique
  passwordHash  String
  realName      String
  organization  String
  role          String    @default("applicant") // applicant, reviewer, approver, admin
  email         String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  applications       Application[]      @relation("Applicant")
  reviews            Review[]
  assignedStages     ApplicationStage[] @relation("Reviewer")
  uploadedDocuments  Document[]
  notifications      Notification[]
  auditLogs          AuditLog[]
}

// ============================================================
// 注册体系（NMPA / FDA / EMA）
// ============================================================
model RegulatorySystem {
  id        Int       @id @default(autoincrement())
  code      String    @unique  // "NMPA", "FDA", "EMA"
  name      String              // "中国NMPA", "美国FDA", "欧盟EMA"
  fullName  String
  createdAt DateTime  @default(now())

  applications Application[]
}

// ============================================================
// 药品注册申请（大幅扩展）
// ============================================================
model Application {
  id                Int       @id @default(autoincrement())
  applicationNo     String?   @unique
  // 注册体系
  regulatorySystemId Int
  regulatorySystem   RegulatorySystem @relation(fields: [regulatorySystemId], references: [id])
  // 申请分类
  type              String    // IND, NDA, ANDA, BLA, supplementary, renewal, variation
  applicationCategory String? // clinical_trial, marketing_auth, supplement, renewal, api_registration
  registrationClass String?   // 化药1-5类 / 生物制品 / 中药
  // 药品信息
  drugName          String
  drugType          String    // 化学药品, 生物制品, 中药
  genericName       String?   // 通用名
  tradeName         String?   // 商品名
  dosageForm        String?   // 剂型：片剂/注射剂/胶囊等
  specification     String?
  indication        String?   // 适应症
  usageDosage       String?   // 用法用量
  atcCode           String?   // ATC分类
  // 生产信息
  applicantId       Int
  applicant         User      @relation("Applicant", fields: [applicantId], references: [id])
  manufacturer      String?
  isOverseas        Boolean   @default(false) // 境外生产
  productionSite    String?   // 生产地址
  // 状态
  status            String    @default("draft") // draft, submitted, under_review, supplement_needed, approved, rejected
  // 特殊属性
  priorityReview      Boolean @default(false) // 优先审评
  breakthroughTherapy  Boolean @default(false) // 突破性治疗
  orphanDrug          Boolean @default(false) // 孤儿药
  emergencyUse        Boolean @default(false) // 特殊管理药品
  isSmallEnterprise   Boolean @default(false) // 小微企业
  // 缴费
  feePayer          String?   // 缴费负责人（是/否）
  // 时间
  submittedAt       DateTime?
  approvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // 关系
  stages          ApplicationStage[]
  documents       Document[]
  reviews         Review[]
  notifications   Notification[]
  enterpriseInfo  EnterpriseInfo?
  croInfos        CROInfo[]
  patentDeclarations PatentDeclaration[]
  ctdModules      CTDModule[]
  fdaInfo         FDARegistration?
  emaInfo         EMARegistration?
  deficiencyLetters  DeficiencyLetter[]
  dmfReferences      DMFReference[]
  postApprovalChanges PostApprovalChange[]
  labelings         Labeling[]
}

// ============================================================
// 企业信息（参照NMPA申请表）
// ============================================================
model EnterpriseInfo {
  id                  Int    @id @default(autoincrement())
  applicationId       Int    @unique
  application         Application @relation(fields: [applicationId], references: [id])
  businessLicense     String? // 营业执照号
  productionLicense   String? // 药品生产许可证编号
  gmpCertificate      String? // GMP证书
  legalRepresentative String? // 法定代表人
  contactPerson       String? // 联系人
  contactPhone        String? // 联系电话
  contactEmail        String? // 联系邮箱
  contactFax          String? // 传真
  contactMobile       String? // 手机
  productionAddress   String? // 生产地址
  mailingAddress      String? // 通讯地址
  productionPostal    String? // 生产地址邮编
  mailingPostal       String? // 通讯地址邮编
  qualityDirector     String? // 质量负责人
  legalRepPosition    String? // 法定代表人职位
  contactPosition     String? // 联系人职位
  qualityDirPosition  String? // 质量负责人职位
  createdAt           DateTime @default(now())
}

// ============================================================
// 委托研究机构 CRO
// ============================================================
model CROInfo {
  id                Int    @id @default(autoincrement())
  applicationId     Int
  application       Application @relation(fields: [applicationId], references: [id])
  orgName           String       // 研究机构名称
  responsiblePerson String       // 研究负责人
  contactInfo       String?      // 联系方式
  studyPhase        String?      // 研究内容
  createdAt         DateTime @default(now())
}

// ============================================================
// 专利声明
// ============================================================
model PatentDeclaration {
  id               Int    @id @default(autoincrement())
  applicationId    Int
  application      Application @relation(fields: [applicationId], references: [id])
  patentNo         String       // 专利号
  patentOwner      String       // 专利权人
  grantDate        DateTime?    // 授权日期
  hasForeignPatent Boolean @default(false)
  nonInfringement  Boolean @default(false)
  createdAt        DateTime @default(now())
}

// ============================================================
// CTD文档模块结构（ICH M4）
// ============================================================
model CTDModule {
  id            Int    @id @default(autoincrement())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id])
  moduleNumber  String       // "1", "2", "3", "4", "5"
  moduleName    String       // 行政信息/总结/质量/非临床/临床
  createdAt     DateTime @default(now())

  subModules CTDSubModule[]
}

model CTDSubModule {
  id          Int    @id @default(autoincrement())
  ctdModuleId Int
  ctdModule   CTDModule @relation(fields: [ctdModuleId], references: [id])
  subNumber   String       // "3.2.S.1", "3.2.P.2" etc
  subName     String       // 基本信息/生产/特性鉴定...
  isRequired  Boolean @default(true)
  createdAt   DateTime @default(now())

  documents Document[]
}

// ============================================================
// FDA特定信息
// ============================================================
model FDARegistration {
  id              Int    @id @default(autoincrement())
  applicationId   Int    @unique
  application     Application @relation(fields: [applicationId], references: [id])
  dunsNumber      String? // DUNS号
  feiNumber       String? // FEI工厂识别号
  esgAccount      String? // ESG账号
  usAgentName     String? // 美国代理人
  usAgentContact  String? // 美国代理人联系方式
  usAgentEmail    String? // 美国代理人邮箱
  ndcNumber       String? // NDC号
  preAssignedBla  String? // Pre-assigned BLA number
  proprietaryName String? // 专有名称
  applicationForm  String? // 356h/1571 form type
  // Paragraph I-IV patent certification (Hatch-Waxman Act)
  patentCertPara     String? // Paragraph I, II, III, or IV
  patentCertNumber   String? // Patent number for certification
  patentCertExpiry   DateTime? // Patent expiry date
  patentCertNotice   Boolean @default(false) // Para IV: 30-month stay notice sent
  createdAt       DateTime @default(now())
}

// ============================================================
// EMA特定信息
// ============================================================
model EMARegistration {
  id                Int    @id @default(autoincrement())
  applicationId     Int    @unique
  application       Application @relation(fields: [applicationId], references: [id])
  procedureType     String       // CP, DCP, MRP, INP
  rmsCountry        String?      // Reference Member State
  cmsCountries      String?      // Concerned Member States (JSON)
  orphanDesignation Boolean @default(false)
  paediatricPlan    Boolean @default(false)
  saProcedure       Boolean @default(false) // Scientific Advice
  saNumber          String?
  maaNumber         String?      // MAA number (EMEA/H/C/...)
  createdAt         DateTime @default(now())
}

// ============================================================
// 审评阶段
// ============================================================
model ApplicationStage {
  id                 Int       @id @default(autoincrement())
  applicationId      Int
  application        Application @relation(fields: [applicationId], references: [id])
  stageName          String
  stageOrder         Int
  status             String    @default("pending") // pending, in_progress, paused, completed, skipped
  assignedReviewerId Int?
  assignedReviewer   User?     @relation("Reviewer", fields: [assignedReviewerId], references: [id])
  startedAt          DateTime?
  completedAt        DateTime?
  deadline           DateTime?
  notes              String?
  // Clock-Stop 机制（EMA/FDA/NMPA发补）: 记录审评时钟暂停/恢复时间
  clockStoppedAt     DateTime?
  clockRestartedAt   DateTime?
  // 平行审评三线（NMPA技术审评）: 三条审评线的独立状态
  reviewTrack        String?   // pharmaceutical, nonclinical, clinical
  trackStatus        String?   // 该审评线的独立状态
  reviews            Review[]
  deficiencyLetters  DeficiencyLetter[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// ============================================================
// 文档
// ============================================================
model Document {
  id             Int       @id @default(autoincrement())
  applicationId  Int
  application    Application @relation(fields: [applicationId], references: [id])
  ctdSubModuleId Int?
  ctdSubModule   CTDSubModule? @relation(fields: [ctdSubModuleId], references: [id])
  documentType   String
  fileName       String
  filePath       String
  fileSize       Int?       // bytes
  version        Int       @default(1)
  docStatus      String    @default("submitted") // draft, submitted, accepted, rejected
  uploadedById   Int
  uploadedBy     User      @relation(fields: [uploadedById], references: [id])
  uploadedAt     DateTime  @default(now())
}

// ============================================================
// 审评意见
// ============================================================
model Review {
  id            Int       @id @default(autoincrement())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id])
  stageId       Int?
  stage         ApplicationStage? @relation(fields: [stageId], references: [id])
  reviewerId    Int
  reviewer      User      @relation(fields: [reviewerId], references: [id])
  content       String
  action        String?   // approve, request_supplement, reject, comment
  isInternal    Boolean   @default(false)
  createdAt     DateTime  @default(now())
}

// ============================================================
// 通知
// ============================================================
model Notification {
  id            Int       @id @default(autoincrement())
  userId        Int
  user          User      @relation(fields: [userId], references: [id])
  applicationId Int?
  application   Application? @relation(fields: [applicationId], references: [id])
  title         String
  message       String
  type          String
  isRead        Boolean   @default(false)
  createdAt     DateTime  @default(now())
}

// ============================================================
// P0: 发补/补正通知（Deficiency Letter）- 支持多轮发补循环
// ============================================================
model DeficiencyLetter {
  id             Int       @id @default(autoincrement())
  applicationId  Int
  application    Application @relation(fields: [applicationId], references: [id])
  stageId        Int
  stage          ApplicationStage @relation(fields: [stageId], references: [id])
  round          Int       // 发补轮次（1, 2, 3...）
  track          String?   // 审评线: pharmaceutical, nonclinical, clinical
  issueDate      DateTime  @default(now())
  dueDate        DateTime  // 补正截止日期（通常4个月）
  responseDate   DateTime? // 实际补正提交日期
  status         String    @default("issued") // issued, responded, accepted, rejected
  questions      String    // JSON: [{category, question, guidance}]
  internalNotes  String?   // 内部审评备注
  createdAt      DateTime  @default(now())
}

// ============================================================
// P1: DMF/原料药引用 - 支持DMF授权信（LOA）机制
// ============================================================
model DMFReference {
  id                Int      @id @default(autoincrement())
  applicationId     Int
  application       Application @relation(fields: [applicationId], references: [id])
  dmfType           String   // API, excipient, packaging
  dmfNumber         String   // DMF号 / 原料药登记号（如Y20230001）
  dmfHolder         String   // DMF持有人
  authorizationLetter Boolean @default(false) // LOA是否已提交
  createdAt         DateTime @default(now())
}

// ============================================================
// P1: 产品上市后变更 - 生命周期管理
// ============================================================
model PostApprovalChange {
  id                Int       @id @default(autoincrement())
  applicationId     Int
  application       Application @relation(fields: [applicationId], references: [id])
  changeType        String    // variation, annual_report, renewal, labeling_update
  changeCategory    String    // NMPA: 审批类/备案类/报告类  FDA: PAS/CBE-30/CBE-0/AR  EMA: TypeIA/IB/II
  changeDescription String
  submissionDate    DateTime?
  approvalDate      DateTime?
  status            String    @default("draft")
  createdAt         DateTime  @default(now())
}

// ============================================================
// P2: 审计追踪 - GxP合规要求
// ============================================================
model AuditLog {
  id          Int      @id @default(autoincrement())
  entityType  String   // Application, Review, Document, etc.
  entityId    Int
  action      String   // CREATE, UPDATE, DELETE, SUBMIT, APPROVE, REJECT
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  changes     String   // JSON: {field: {old: ..., new: ...}}
  createdAt   DateTime @default(now())
}

// ============================================================
// P1: 说明书/标签 - SmPC/PIL/标签审评
// ============================================================
model Labeling {
  id                Int       @id @default(autoincrement())
  applicationId     Int
  application       Application @relation(fields: [applicationId], references: [id])
  labelType         String    // SmPC, PIL, carton, vial_label, blister
  language          String    @default("zh-CN")
  version           Int       @default(1)
  content           String    // 说明书全文
  negotiationStatus String    @default("draft") // draft, under_review, agreed, final
  createdAt         DateTime  @default(now())
}
